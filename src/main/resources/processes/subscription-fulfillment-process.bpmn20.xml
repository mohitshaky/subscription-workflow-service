<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://www.flowable.org/processdef">

    <process id="subscriptionFulfillmentProcess" name="Subscription Fulfillment Process" isExecutable="true">

        <!-- Start Event -->
        <startEvent id="startEvent" name="Subscription Received">
            <documentation>Customer subscription received, initiating fulfillment process</documentation>
        </startEvent>

        <!-- Sequence Flow: Start -> Validate -->
        <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="validateSubscriptionTask"/>

        <!-- Service Task: Validate Subscription -->
        <serviceTask id="validateSubscriptionTask"
                     name="Validate Subscription"
                     flowable:class="com.mohit.subscription.workflow.delegate.ValidateSubscriptionDelegate">
            <documentation>Validates subscription data and publishes validation event to SW_VALIDATION_STATUS Kafka topic</documentation>
        </serviceTask>

        <!-- Sequence Flow: Validate -> Wait for Provisioning -->
        <sequenceFlow id="flow2" sourceRef="validateSubscriptionTask" targetRef="waitForProvisioningTask"/>

        <!-- User Task: Wait for Provisioning -->
        <userTask id="waitForProvisioningTask"
                  name="Wait for Provisioning"
                  flowable:assignee="system">
            <documentation>Waits for provisioning completion event from SW_PROVISIONING_RESULT Kafka topic via ProvisioningResultEventListener</documentation>
        </userTask>

        <!-- Sequence Flow: Wait -> Update Status -->
        <sequenceFlow id="flow3" sourceRef="waitForProvisioningTask" targetRef="updateSubscriptionStatusTask"/>

        <!-- Service Task: Update Subscription Status -->
        <serviceTask id="updateSubscriptionStatusTask"
                     name="Update Subscription Status"
                     flowable:class="com.mohit.subscription.workflow.delegate.UpdateSubscriptionStatusDelegate">
            <documentation>Updates subscription status and publishes SubscriptionStatusEvent to SW_SUBSCRIPTION_STATUS Kafka topic</documentation>
        </serviceTask>

        <!-- Sequence Flow: Update Status -> Notify -->
        <sequenceFlow id="flow4" sourceRef="updateSubscriptionStatusTask" targetRef="sendActivationNotificationTask"/>

        <!-- Service Task: Send Activation Notification -->
        <serviceTask id="sendActivationNotificationTask"
                     name="Send Activation Notification"
                     flowable:class="com.mohit.subscription.workflow.delegate.SendActivationNotificationDelegate">
            <documentation>Sends customer activation notification event to SW_NOTIFICATION Kafka topic</documentation>
        </serviceTask>

        <!-- Sequence Flow: Notify -> End -->
        <sequenceFlow id="flow5" sourceRef="sendActivationNotificationTask" targetRef="endEvent"/>

        <!-- End Event -->
        <endEvent id="endEvent" name="Subscription Activated">
            <documentation>Subscription fulfillment process completed successfully</documentation>
        </endEvent>

    </process>

    <bpmndi:BPMNDiagram id="BPMNDiagram_subscriptionFulfillmentProcess">
        <bpmndi:BPMNPlane id="BPMNPlane_subscriptionFulfillmentProcess" bpmnElement="subscriptionFulfillmentProcess">

            <bpmndi:BPMNShape id="BPMNShape_startEvent" bpmnElement="startEvent">
                <omgdc:Bounds x="152" y="82" width="36" height="36"/>
                <bpmndi:BPMNLabel>
                    <omgdc:Bounds x="125" y="125" width="90" height="14"/>
                </bpmndi:BPMNLabel>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="BPMNShape_validateSubscriptionTask" bpmnElement="validateSubscriptionTask">
                <omgdc:Bounds x="250" y="60" width="120" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="BPMNShape_waitForProvisioningTask" bpmnElement="waitForProvisioningTask">
                <omgdc:Bounds x="430" y="60" width="140" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="BPMNShape_updateSubscriptionStatusTask" bpmnElement="updateSubscriptionStatusTask">
                <omgdc:Bounds x="630" y="60" width="140" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="BPMNShape_sendActivationNotificationTask" bpmnElement="sendActivationNotificationTask">
                <omgdc:Bounds x="830" y="60" width="140" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="BPMNShape_endEvent" bpmnElement="endEvent">
                <omgdc:Bounds x="1032" y="82" width="36" height="36"/>
                <bpmndi:BPMNLabel>
                    <omgdc:Bounds x="1005" y="125" width="90" height="14"/>
                </bpmndi:BPMNLabel>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNEdge id="BPMNEdge_flow1" bpmnElement="flow1">
                <omgdi:waypoint x="188" y="100"/>
                <omgdi:waypoint x="250" y="100"/>
            </bpmndi:BPMNEdge>

            <bpmndi:BPMNEdge id="BPMNEdge_flow2" bpmnElement="flow2">
                <omgdi:waypoint x="370" y="100"/>
                <omgdi:waypoint x="430" y="100"/>
            </bpmndi:BPMNEdge>

            <bpmndi:BPMNEdge id="BPMNEdge_flow3" bpmnElement="flow3">
                <omgdi:waypoint x="570" y="100"/>
                <omgdi:waypoint x="630" y="100"/>
            </bpmndi:BPMNEdge>

            <bpmndi:BPMNEdge id="BPMNEdge_flow4" bpmnElement="flow4">
                <omgdi:waypoint x="770" y="100"/>
                <omgdi:waypoint x="830" y="100"/>
            </bpmndi:BPMNEdge>

            <bpmndi:BPMNEdge id="BPMNEdge_flow5" bpmnElement="flow5">
                <omgdi:waypoint x="970" y="100"/>
                <omgdi:waypoint x="1032" y="100"/>
            </bpmndi:BPMNEdge>

        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>

</definitions>
